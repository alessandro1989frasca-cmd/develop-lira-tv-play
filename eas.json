{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "cache": {
        "disabled": true
      },
      "android": {
        "buildType": "app-bundle",
        "distribution": "store",
        "gradleCommand": ":app:bundleRelease -x :expo-location:build -x :expo-location:compileReleaseKotlin -x :expo-location:compileDebugKotlin"
      },
      "env": {
        "EAS_NO_BUN": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
