{
  "expo": {
    "name": "Lira TV Play",
    "slug": "lira-tv-play",
    "version": "1.0.104",
    "privacyUrl": "https://www.liratv.it/privacy-policy/",
    "icon": "./assets/images/icon.png",
    "scheme": "lira-tv-play",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "it.liratv.play",
      "buildNumber": "1.0.3",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "it.liratv.play",
      "googleServicesFile": "./google-services.json",
      "versionCode": 179,
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://liratv.it/"
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#EF4444",
          "defaultChannel": "urgent-news"
        }
      ],
      "expo-web-browser",
      "./plugins/removeBootCompleted",
      "./plugins/swiftConcurrencyMinimal",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          },
          "ios": {
            "extraPodfileProperties": {
              "SWIFT_STRICT_CONCURRENCY": "minimal"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "autolinking": {
      "exclude": [
        "expo-location",
        "@teovilla/react-native-web-maps"
      ],
      "android": {
        "exclude": [
          "expo-location",
          "@teovilla/react-native-web-maps",
          "expo-audio"
        ]
      },
      "ios": {
        "exclude": [
          "expo-location",
          "@teovilla/react-native-web-maps"
        ]
      }
    },
    "extra": {
      "eas": {
        "projectId": "b92878f0-1546-48fd-a3b8-69ae95ea42b4"
      }
    }
  }
}
